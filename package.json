{
  "name": "gym-app-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm --filter gym-app dev\" \"pnpm --filter backend start:dev\" --names \"frontend,backend\" --prefix-colors \"cyan,magenta\"",
    "dev:frontend": "pnpm --filter gym-app dev",
    "dev:backend": "pnpm --filter backend start:dev",
    "build": "pnpm --filter gym-app build && pnpm --filter backend build",
    "format": "prettier --write .",
    "typecheck": "pnpm --filter gym-app typecheck && pnpm --filter backend build",
    "lint": "pnpm --filter gym-app lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1"
  }
}
