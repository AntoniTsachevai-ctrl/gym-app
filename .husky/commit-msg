commit_msg=$(cat "$1")

pattern="^(feat|fix|chore|docs|refactor|style|test|perf|ci|build|revert)(\(.+\))?: .{1,}"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "❌ Invalid commit message format!"
  echo ""
  echo "Expected: <type>(<optional scope>): <description>"
  echo ""
  echo "Allowed types: feat, fix, chore, docs, refactor, style, test, perf, ci, build, revert"
  echo ""
  echo "Examples:"
  echo "  feat: add user login"
  echo "  fix(auth): resolve token expiry issue"
  echo "  chore: update dependencies"
  echo ""
  echo "Your message: $commit_msg"
  echo ""
  exit 1
fi
